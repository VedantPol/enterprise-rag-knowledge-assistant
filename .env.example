# FastAPI
APP_NAME="Enterprise RAG Knowledge Assistant"
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# Optional Docker Hub image tag for docker compose build/push.
DOCKER_IMAGE=your-dockerhub-username/enterprise-rag-assistant:latest

# Pinecone. Leave PINECONE_API_KEY blank for local in-memory demo mode.
PINECONE_API_KEY=replace-me
PINECONE_INDEX_NAME=enterprise-rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=default

# Embeddings. Keep EMBEDDING_DIM in sync with the selected model.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# PDF chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=180

# Retrieval and reranking
RETRIEVAL_TOP_K=12
RERANK_TOP_K=5
# Leave blank to disable neural reranking and use vector scores only.
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Gemini answer generation. Free-tier Gemini API keys work here.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional OpenAI fallback. Without an LLM key, the app returns an extractive
# citation-grounded answer from the retrieved passages.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

SEED_SAMPLE_DATA=true

# Optional CORS origins, comma-separated. "*" is convenient behind a tunnel
# when the FastAPI app is not exposed elsewhere.
ALLOWED_ORIGINS=*

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=replace-me
